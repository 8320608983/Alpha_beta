using UnityEngine;

public class CoinPool : MonoBehaviour
{
    public static CoinPool Instance;
    public Coin prefab;
    public int poolSize;
    Queue<Coin> coins = new Queue<Coin>();
    List<Coin> activeCoins = new List<Coin>();
    private void Awake()
    {
        if (Instance == null) Instance = this;
        GeneratePool();
    }

    private void GeneratePool()
    {
        for (int i = 0; i < poolSize; i++)
        {
            Coin c = Instantiate(prefab, transform);
            c.gameObject.SetActive(false);
            coins.Enqueue(c); activeCoins.Add(c);
        }
    }
    public Coin GetCoin()
    {
        Coin c;
        if (coins.Count > 0)
        {
            c = coins.Dequeue();
        }
        else
        {
            c = Instantiate(prefab, transform);
        }
        activeCoins.Add(c);
        c.gameObject.SetActive(true);
        return c;
    }

    public void ReturnPool(Coin c)
    {
        coins.Enqueue(c); activeCoins.Remove(c);
        c.gameObject.SetActive(false);
    }
    public void ResetPool()
    {
        foreach (Coin c in activeCoins.ToArray())
        {
            ReturnPool(c);
        }

        activeCoins.Clear();
    }
}
using UnityEngine;

public class CoinSpawner : MonoBehaviour
{
    public Transform player;

    public float startingDistance = 20f;
    public float difference = 10f;

    public int initialSpawnCount = 10;

    float lastPosZ;

    int laneCount => player.GetComponent<PlayerMovement>().laneCount;
    float laneDistance => player.GetComponent<PlayerMovement>().laneDistance;

    private void OnEnable()
    {
        GameEvents.OnGameStart += StartSpawner;
        GameEvents.OnGameReset += StartSpawner;
    }

    private void OnDisable()
    {
        GameEvents.OnGameStart -= StartSpawner;
        GameEvents.OnGameReset -= StartSpawner;
    }

    void StartSpawner()
    {
        CoinPool.Instance.ResetPool();

        lastPosZ = player.position.z + startingDistance;

        for (int i = 0; i < initialSpawnCount; i++)
        {
            SpawnCoin();
        }
    }

    void Update()
    {
        if (!GameManager.Instance.IsGameRunning) return;

        if (player.position.z > lastPosZ - startingDistance)
        {
            SpawnCoin();
        }
    }

    void SpawnCoin()
    {
        int lane = Random.Range(0, laneCount);

        Coin c = CoinPool.Instance.GetCoin();

        c.transform.position = new Vector3(GetX(lane), 1, lastPosZ);

        c.player = player;

        lastPosZ += difference;
    }

    float GetX(int lane)
    {
        float midLane = (laneCount - 1) / 2f;

        return (midLane - lane) * laneDistance;
    }
