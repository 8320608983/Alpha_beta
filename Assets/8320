public class TileSpawner : MonoBehaviour
{
    public Transform player;

    public int onScreenTileAmount = 7;
    public float tileLength = 30f;

    float spawnZ = 0;

    List<Tile> activeTiles = new List<Tile>();

    private void OnEnable()
    {
        GameEvents.OnGameStart += StartSpawn;
        GameEvents.OnGameReset += ResetTiles;
    }

    private void OnDisable()
    {
        GameEvents.OnGameStart -= StartSpawn;
        GameEvents.OnGameReset -= ResetTiles;
    }

    void StartSpawn()
    {
        ClearTiles();

        spawnZ = 0;

        for (int i = 0; i < onScreenTileAmount; i++)
        {
            SpawnTile();
        }
    }

    void SpawnTile()
    {
        Tile t = TilePool.Instance.GetTile();

        t.transform.position = new Vector3(0, 0, spawnZ);

        spawnZ += tileLength;

        activeTiles.Add(t);
    }

    void Update()
    {
        if (!GameManager.Instance.IsGameRunning) return;

        if (player.position.z - 20f > spawnZ - (onScreenTileAmount * tileLength))
        {
            SpawnTile();
            RemoveOldTile();
        }
    }

    void RemoveOldTile()
    {
        Tile oldTile = activeTiles[0];

        activeTiles.RemoveAt(0);

        TilePool.Instance.SendBack(oldTile);
    }

    void ResetTiles()
    {
        StartSpawn();
    }

    void ClearTiles()
    {
        foreach (Tile t in activeTiles)
        {
            TilePool.Instance.SendBack(t);
        }

        activeTiles.Clear();
    }
