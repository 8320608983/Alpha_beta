public class ObstPool : MonoBehaviour
{
    public static ObstPool Instance;
    public Obstacle obstacle;
    public int poolsize = 20;
    Queue<Obstacle> obstacleQueue = new Queue<Obstacle>();
    List<Obstacle> activeObstacles = new List<Obstacle>();
    private void Awake()
    {
        if (Instance == null) Instance = this;
        CreatePool();
    }

    private void CreatePool()
    {
        for (int i = 0; i < poolsize; i++)
        {
            Obstacle obs = Instantiate(obstacle, transform);
            obs.gameObject.SetActive(false);
            obstacleQueue.Enqueue(obs); 
            activeObstacles.Add(obs);
        }
    }

    public Obstacle GetObstacle()
    {
        Obstacle obst;
        if (obstacleQueue.Count > 0)
        {
            obst = obstacleQueue.Dequeue();
        }
        else
        {
            obst = Instantiate(obstacle, transform);
        }
        activeObstacles.Add(obst);
        obst.gameObject.SetActive(true);
        return obst;
    }
    public void ReturnObstacle(Obstacle obstacle)
    {
        obstacleQueue.Enqueue(obstacle);
        activeObstacles.Remove(obstacle);
        obstacle.gameObject.SetActive(false);
    }
    public void ResetPool()
    {
        foreach (Obstacle o in activeObstacles.ToArray())
        {
            ReturnObstacle(o);
        }

        activeObstacles.Clear();
    }
}
