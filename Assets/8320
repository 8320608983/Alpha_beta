public class PlayerMovement : MonoBehaviour
{

    float forwardSpeed = 10f;
    float startSpeedRate = 0.2f;
    float laneChnageSpeed = 12f;
    internal int laneCount = 5;
    internal float laneDistance = 2f;

    int currentLaneIndex;
    CharacterController characterController;
    Vector3 startpos, velocity;
    bool canMove;
    float jumpForce = 10f;
    float gravity = -20f;

    private void Awake()
    {
        characterController = GetComponent<CharacterController>();
    }
    private void OnEnable()
    {
        GameEvents.OnGameStart += EnableMovement;
        GameEvents.OnGameEnd += DisableMovement;
        GameEvents.OnGameReset += ResetPlayer;
    }

    private void OnDisable()
    {
        GameEvents.OnGameStart -= EnableMovement;
        GameEvents.OnGameEnd -= DisableMovement;
        GameEvents.OnGameReset -= ResetPlayer;
    }

    void EnableMovement()
    {
        canMove = true;
    }

    void DisableMovement()
    {
        canMove = false;
    }

    void ResetPlayer()
    {
        characterController.enabled = false;
        transform.position = startpos;
        velocity = Vector3.zero;
        forwardSpeed = 8f;
        currentLaneIndex = laneCount / 2;
        characterController.enabled = true;
    }
    private void Start()
    {
        startpos = transform.position;
        currentLaneIndex = laneCount / 2;
        print("Lane Index : " + currentLaneIndex);
    }
    private void Update()
    {
        if (!canMove) return;

        forwardSpeed = forwardSpeed + startSpeedRate * Time.deltaTime;

        Vector3 move = Vector3.forward * forwardSpeed;

        if (Input.GetKeyDown(KeyCode.A))
        {
            ChangeLane(-1);
        }

        if (Input.GetKeyDown(KeyCode.D))
        {
            ChangeLane(1);
        }

        if (characterController.isGrounded)
        {
            velocity.y = -1f;

            if (Input.GetKeyDown(KeyCode.Space))
            {
                velocity.y = jumpForce;
            }
        }
        else
        {
            velocity.y += gravity * Time.deltaTime;
        }

        float targetX = GetValueX(currentLaneIndex);
        float distanceX = targetX - transform.position.x;

        move.x = distanceX * laneChnageSpeed;

        characterController.Move((move + velocity) * Time.deltaTime);

        GameEvents.OnDistanceChanged?.Invoke(transform.position.z);
    }

    private float GetValueX(int LaneIndex)
    {
        float middleLane = (laneCount - 1) / 2;
        return (LaneIndex - middleLane) * laneDistance;
    }

    private void ChangeLane(int laneIndex)
    {
        currentLaneIndex = currentLaneIndex + laneIndex;
        currentLaneIndex = Mathf.Clamp(currentLaneIndex, 0, laneCount - 1);
    }
    private void OnControllerColliderHit(ControllerColliderHit hit)
    {
        if (hit.gameObject.CompareTag("Obstacle"))
        {
            if (!GameManager.Instance.IsGameOver)
            {

                //print("GameOver");
                GameManager.Instance.GameOver();
            }
        }
    }
}
