using UnityEngine;

[RequireComponent(typeof(Rigidbody))]
public class PlayerMovement : MonoBehaviour
{
    [Header("Forward Movement")]
    [SerializeField] float forwardSpeed = 10f;
    [SerializeField] float speedIncreaseRate = 0.2f;

    [Header("Lane Movement")]
    [SerializeField] float laneChangeSpeed = 10f;
    internal int laneCount = 5;
    internal float laneDistance = 2f;

    [Header("Jump")]
    [SerializeField] float jumpForce = 7f;

    Rigidbody rb;

    int currentLaneIndex;

    Vector3 startPos;

    bool canMove;
    bool isGrounded;

    private void Awake()
    {
        rb = GetComponent<Rigidbody>();

        rb.interpolation = RigidbodyInterpolation.Interpolate;
        rb.collisionDetectionMode = CollisionDetectionMode.Continuous;

        // Prevent player from falling sideways
        rb.constraints =
            RigidbodyConstraints.FreezeRotationX |
            RigidbodyConstraints.FreezeRotationZ;
    }

    private void Start()
    {
        startPos = transform.position;

        currentLaneIndex = laneCount / 2;
    }

    private void OnEnable()
    {
        GameEvents.OnGameStart += EnableMovement;
        GameEvents.OnGameEnd += DisableMovement;
        GameEvents.OnGameReset += ResetPlayer;
    }

    private void OnDisable()
    {
        GameEvents.OnGameStart -= EnableMovement;
        GameEvents.OnGameEnd -= DisableMovement;
        GameEvents.OnGameReset -= ResetPlayer;
    }

    void EnableMovement()
    {
        canMove = true;
    }

    void DisableMovement()
    {
        canMove = false;

        rb.velocity = Vector3.zero;
    }

    void ResetPlayer()
    {
        rb.velocity = Vector3.zero;

        transform.position = startPos;

        forwardSpeed = 10f;

        currentLaneIndex = laneCount / 2;
    }

    private void Update()
    {
        if (!canMove) return;

        HandleInput();

        GameEvents.OnDistanceChanged?.Invoke(transform.position.z);
    }

    private void FixedUpdate()
    {
        if (!canMove) return;

        MoveForward();

        HandleLaneMovement();
    }

    void HandleInput()
    {
        if (Input.GetKeyDown(KeyCode.A))
        {
            ChangeLane(-1);
        }

        if (Input.GetKeyDown(KeyCode.D))
        {
            ChangeLane(1);
        }

        if (Input.GetKeyDown(KeyCode.Space) && isGrounded)
        {
            Jump();
        }
    }

    void MoveForward()
    {
        forwardSpeed += speedIncreaseRate * Time.fixedDeltaTime;

        Vector3 velocity = rb.velocity;

        velocity.z = forwardSpeed;

        rb.velocity = velocity;
    }

    void HandleLaneMovement()
    {
        float targetX = GetLanePositionX(currentLaneIndex);

        float difference = targetX - transform.position.x;

        Vector3 velocity = rb.velocity;

        velocity.x = difference * laneChangeSpeed;

        rb.velocity = velocity;
    }

    void Jump()
    {
        rb.AddForce(Vector3.up * jumpForce, ForceMode.Impulse);

        isGrounded = false;
    }

    float GetLanePositionX(int laneIndex)
    {
        float middleLane = (laneCount - 1) / 2f;

        return (laneIndex - middleLane) * laneDistance;
    }

    void ChangeLane(int direction)
    {
        currentLaneIndex += direction;

        currentLaneIndex = Mathf.Clamp(
            currentLaneIndex,
            0,
            laneCount - 1
        );
    }

    private void OnCollisionEnter(Collision collision)
    {
        if (collision.gameObject.CompareTag("Ground"))
        {
            isGrounded = true;
        }

        if (collision.gameObject.CompareTag("Obstacle"))
        {
            if (!GameManager.Instance.IsGameOver)
            {
                GameManager.Instance.GameOver();
            }
        }
    }
